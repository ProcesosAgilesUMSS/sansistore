---
import InventoryLayout from '@layouts/InventoryLayout.astro';
import { OrderDispatch } from '@features/inventory/components/OrderDispatch.tsx';
import { WarehouseHandover } from '@features/inventory/components/WarehouseHandover.tsx';
---

<InventoryLayout title="Sansistore | Movimientos">
  <section class="mb-8">
    <div class="mb-4">
      <h2
        class="font-display font-black text-2xl tracking-tight text-(--theme-text)"
      >
        Gestión de <span class="text-primary">Despachos</span>
      </h2>
      <p class="text-xs opacity-60 text-(--theme-text)">
        Preparación de paquetes y entrega física a mostrador.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-1 gap-8 items-stretch">
      <OrderDispatch client:load />
      {/*<WarehouseHandover client:load />*/}
      {/* eliminar archivo WarehouseHandover */}
    </div>
  </section>

  <hr class="border-(--theme-border)/50 my-10" />
</InventoryLayout>
