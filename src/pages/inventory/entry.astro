---
// src/pages/inventory/entry.astro
import Layout from '../../layouts/Layout.astro';
import { LotEntryForm } from '../../features/inventory/components/LotEntryForm.tsx';
---

<Layout title="Sansistore | Registro de Lotes">
  <main className="p-6 md:p-10 bg-gray-50 min-h-screen">
    
    <div className="max-w-lg mx-auto">
        <div className="mb-6">
            <a href="/inventory" className="text-blue-600 hover:underline text-sm font-medium">
                &larr; Volver al Panel
            </a>
            <h1 className="text-2xl font-bold text-gray-900 mt-2">Registro de Ingreso</h1>
            <p className="text-gray-600 text-sm mt-1">Aumenta el stock de un producto existente.</p>
        </div>

        <div className="bg-white p-6 rounded-xl shadow-md border border-gray-100 relative">
            <LotEntryForm client:load />
        </div>
    </div>
    
  </main>
</Layout>