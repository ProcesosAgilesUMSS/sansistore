---
import SellerLayout from '../../layouts/SellerLayout.astro';
import OfferForm from '../../features/offers/components/OfferForm';
---

<SellerLayout title="Sansistore | Gestionar Ofertas">
  <div class="py-6 lg:py-8">
    <div class="mb-6">
      <h1 class="font-['Outfit'] font-black text-2xl tracking-tight text-(--theme-text)">
        Gestionar <span class="text-primary">Ofertas</span>
      </h1>
      <p class="mt-1 text-sm text-(--theme-text) opacity-50">
        Crea y administra los descuentos de tus productos.
      </p>
    </div>

    <div class="max-w-2xl">
      <OfferForm client:load />
    </div>
  </div>
</SellerLayout>