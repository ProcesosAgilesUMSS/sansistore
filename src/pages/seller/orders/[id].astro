---
import Layout from '@/layouts/Layout.astro';
import Navbar from '@/components/Navbar';
import Footer from '@/components/Footer';
import OrderDetailView from '@/features/orders/components/OrderDetailView';

export const prerender = false;

const { id } = Astro.params;
---

<Layout title="Pedido | Sansistore">
    <Navbar client:load />
    <main class="flex-1">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 pt-24 pb-32">
            <a
                href="/seller/orders"
                id="back-btn"
                class="mb-4 inline-flex items-center gap-1.5 text-sm text-black/50 hover:text-black/80 transition-colors cursor-pointer"
                aria-label="Volver a pedidos"
            >
                <svg
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                >
                    <path d="M19 12H5"></path>
                    <path d="M12 19l-7-7 7-7"></path>
                </svg>
                Volver a pedidos
            </a>
            <script>
                document.addEventListener('astro:page-load', () => {
                    const backBtn = document.getElementById('back-btn');
                    backBtn?.addEventListener('click', () => {
                        if (
                            document.referrer &&
                            document.referrer.includes(window.location.host)
                        ) {
                            history.back();
                        } else {
                            window.location.href = '/';
                        }
                    });
                });
            </script>
            <div
                id="order-skeleton"
                class="animate-pulse mx-auto w-full max-w-[65ch] max-[760px]:max-w-[480px] grid grid-cols-[repeat(16,_1fr)] max-[760px]:grid-cols-7 p-3 rounded-xl bg-white shadow-2xl border border-black/10"
            >
                <div class="col-span-full h-3 w-3/4 bg-gray-200 rounded"></div>
                <div
                    class="col-span-full flex items-center justify-between mb-6"
                >
                    <div class="h-5 w-48 bg-gray-200 rounded"></div>
                    <div class="h-5 w-20 bg-gray-200 rounded"></div>
                </div>
                {
                    [0, 1, 2].map(() => (
                        <div class="col-span-full grid grid-cols-subgrid items-center mb-2">
                            <div class="col-start-1 col-end-4 max-[760px]:col-end-3 h-3.5 w-14 bg-gray-200 rounded" />
                            <div class="col-start-4 col-end-13 max-[760px]:col-start-3 max-[760px]:col-end-7 h-3.5 w-44 bg-gray-200 rounded" />
                        </div>
                    ))
                }
                <div
                    class="col-span-full grid grid-cols-subgrid border-y border-dashed py-0.5 items-center mt-4 mb-2"
                >
                    <div
                        class="col-start-1 col-end-3 h-3.5 w-10 bg-gray-200 rounded"
                    >
                    </div>
                    <div
                        class="col-start-3 col-end-10 h-3.5 w-20 bg-gray-200 rounded"
                    >
                    </div>
                    <div
                        class="hidden min-[760px]:block col-start-11 col-end-13 h-3.5 w-10 bg-gray-200 rounded"
                    >
                    </div>
                    <div
                        class="hidden min-[760px]:block col-start-13 col-end-16 h-3.5 w-10 bg-gray-200 rounded"
                    >
                    </div>
                    <div
                        class="hidden min-[760px]:block col-start-16 col-end-17 h-3.5 w-8 bg-gray-200 rounded"
                    >
                    </div>
                </div>
                {
                    [0, 1, 2].map(() => (
                        <div class="col-span-full grid grid-cols-subgrid items-center py-1">
                            <div class="col-start-1 col-end-3 h-3.5 w-6 bg-gray-200 rounded" />
                            <div class="col-start-3 col-end-10 h-3.5 w-32 bg-gray-200 rounded" />
                            <div class="hidden min-[760px]:block col-start-11 col-end-13 h-3.5 w-12 bg-gray-200 rounded" />
                            <div class="hidden min-[760px]:block col-start-13 col-end-16 h-3.5 w-12 bg-gray-200 rounded" />
                            <div class="hidden min-[760px]:block col-start-16 col-end-17 h-3.5 w-8 bg-gray-200 rounded" />
                        </div>
                    ))
                }
                <div class="col-span-full py-1.5 border-y border-dashed mt-2">
                    <div class="flex justify-between">
                        <div class="h-3.5 w-28 bg-gray-200 rounded"></div>
                        <div class="h-3.5 w-6 bg-gray-200 rounded"></div>
                    </div>
                    <div class="flex justify-between mt-2">
                        <div class="h-3.5 w-10 bg-gray-200 rounded"></div>
                        <div class="h-3.5 w-14 bg-gray-200 rounded"></div>
                    </div>
                </div>
                <div class="col-span-full flex justify-end mt-6">
                    <div class="h-9 w-28 bg-gray-200 rounded-lg"></div>
                </div>
            </div>
            <OrderDetailView client:load orderId={id} />
        </div>
    </main>
    <Footer client:load />
</Layout>
