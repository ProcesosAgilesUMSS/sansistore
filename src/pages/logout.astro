---
// Simple logout page - handles client-side Firebase logout
---

<script>
  import { signOut } from 'firebase/auth';
  import { auth } from '../lib/firebase';

  signOut(auth)
    .then(() => {
      window.location.href = '/login';
    })
    .catch((error) => {
      console.error('Logout error:', error);
      window.location.href = '/login';
    });
</script>

<p>Logging out...</p>
