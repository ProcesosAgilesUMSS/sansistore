---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import Footer from '../components/Footer';
import ProfileView from '../features/profile/ProfileView';
---

<Layout title="Mi Cuenta | Sansistore">
  <Navbar client:load />

  <main class="flex-1 w-full max-w-xl mx-auto px-4 pt-32 pb-16">
    <header class="flex flex-col items-center gap-4 mb-8 text-center">
      <h1 class="text-[clamp(1.75rem,4vw,3rem)] font-black tracking-[-0.04em] leading-none text-text-light">
        Mi Perfil
      </h1>
    </header>

    <ProfileView client:load />
  </main>

  <Footer client:load />
</Layout>