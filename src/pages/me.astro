---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Mi Cuenta | Sansistore">
  <main class="profile-container">
    <header class="profile-header">
      <img id="user-avatar" src="" alt="" class="profile-avatar" hidden />
      <h1>Mi Perfil</h1>
    </header>

    <section class="profile-details">
      <div id="auth-status" class="loading">Cargando...</div>
    </section>
  </main>

  <script>
    import { onAuthStateChanged } from 'firebase/auth';
    import { auth } from '../lib/firebase';

    const container = document.getElementById('auth-status');

    onAuthStateChanged(auth, (user) => {
      if (!container) return;

      if (user) {
        const displayName = user.displayName || 'Sin nombre';
        const email = user.email || 'No disponible';
        const avatar = document.getElementById('user-avatar') as HTMLImageElement | null;
        if (avatar && user.photoURL) {
          avatar.src = user.photoURL;
          avatar.alt = `Foto de perfil de ${escapeHtml(displayName)}`;
          avatar.hidden = false;
        }
        container.outerHTML = `
          <section class="profile-details">
            <dl class="profile-data">
              <dt>Nombre</dt>
              <dd>${escapeHtml(displayName)}</dd>
              <dt>Correo</dt>
              <dd>${escapeHtml(email)}</dd>
            </dl>
          </section>
        `;
      } else {
        container.outerHTML = `
          <div class="error-message">
            <p>No autenticado</p>
            <a href="/login">Iniciar sesión</a>
          </div>
        `;
      }
    });

    function escapeHtml(text: string): string {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }
  </script>
</Layout>