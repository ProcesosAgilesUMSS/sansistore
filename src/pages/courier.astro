---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import RouteGuard from '../components/RouteGuard';
import DeliveryActionsPanel from '../features/mensajero/components/DeliveryActionsPanel';
---

<Layout title="Mensajero | SansiStore">
  <Navbar client:load />
  <main class="flex h-screen flex-1 overflow-hidden pt-14">
    <RouteGuard client:load allowedRoles={['mensajero']} roleName="Mensajero">
      <DeliveryActionsPanel client:load />
    </RouteGuard>
  </main>
</Layout>
