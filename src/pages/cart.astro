---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import Footer from '../components/Footer';
---

<Layout title="Mi Carrito | SansiStore">
  <Navbar client:load />

  <main class="cart-page max-w-6xl mx-auto px-4 sm:px-6 pt-20 pb-12">
    <h1 class="text-2xl font-bold mb-6">Mi Carrito</h1>

    <div id="cart-status">Cargando...</div>
  </main>

  <script>
    import { onAuthStateChanged } from 'firebase/auth';
    import { collection, getDocs, doc, getDoc } from 'firebase/firestore';
    import { auth, db } from '../lib/firebase';

    const container = document.getElementById('cart-status');

    onAuthStateChanged(auth, async (user) => {
      if (!container) return;

      if (!user) {
        container.outerHTML = `
          <div class="error-message">
            <p>No autenticado</p>
            <a href="/login">Iniciar sesión</a>
          </div>
        `;
        return;
      }

      // Authenticated: load cart items
      try {
        const cartCol = collection(db, 'users', user.uid, 'cartItems');
        const snap = await getDocs(cartCol);

        if (snap.empty) {
          container.outerHTML = `
            <section class="py-12">
              <h2 class="text-xl font-semibold">Mi Carrito</h2>
              <p class="mt-4">Tu carrito está vacío</p>
              <a href="/productos" class="inline-block mt-4 text-primary font-semibold">Ver productos</a>
            </section>
          `;
          return;
        }

        let itemsHtml = '';
        let subtotal = 0;

        for (const docSnap of snap.docs) {
          const data = docSnap.data();
          const quantity = data.quantity || 1;
          const productId = data.productId;

          let product = null;
          try {
            const pRef = doc(db, 'products', productId);
            const pSnap = await getDoc(pRef);
            if (pSnap.exists()) product = pSnap.data();
          } catch (e) {
            // ignore
          }

          const name = product?.name || productId || 'Producto desconocido';
          const price = (product?.hasOffer && product?.offerPrice != null)
            ? product.offerPrice
            : product?.price || 0;

          const lineTotal = price * quantity;
          subtotal += lineTotal;

          itemsHtml += `
            <div class="cart-item">
              <div class="cart-item-title">${escapeHtml(name)}</div>
              <div class="cart-item-qty">Cantidad: ${quantity}</div>
              <div class="cart-item-price">Precio: Bs ${price.toFixed(2)}</div>
            </div>
          `;
        }

        const shipping = 0; // placeholder
        const estimatedTotal = subtotal + shipping;

        container.outerHTML = `
          <div class="grid md:grid-cols-3 gap-8">
            <section class="md:col-span-2 bg-bg-light p-4 rounded-lg border border-border-light">
              ${itemsHtml}
            </section>

            <aside class="cart-summary bg-bg-light p-4 rounded-lg border border-border-light">
              <h3 class="text-lg font-semibold mb-4">Resumen del pedido</h3>
              <div class="flex justify-between mb-2"><span>Subtotal</span><span>Bs ${subtotal.toFixed(2)}</span></div>
              <div class="flex justify-between mb-2"><span>Envío estimado</span><span>Bs ${shipping.toFixed(2)}</span></div>
              <hr class="my-3" />
              <div class="flex justify-between text-lg font-bold mb-4"><span>Total estimado</span><span>Bs ${estimatedTotal.toFixed(2)}</span></div>
              <button class="w-full bg-primary text-white py-2 rounded-lg font-semibold">Confirmar pedido</button>
              <p class="text-sm opacity-60 mt-3">*Precio estimado sujeto a cambios al confirmar el pedido.</p>
            </aside>
          </div>
        `;
      } catch (err) {
        container.outerHTML = `
          <div class="error-message">
            <p>Error al cargar el carrito</p>
          </div>
        `;
      }
    });

    function escapeHtml(text: string) {
      const div = document.createElement('div');
      div.textContent = String(text);
      return div.innerHTML;
    }
  </script>
  <Footer client:idle />
</Layout>
