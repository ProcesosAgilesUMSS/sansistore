---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import Footer from '../components/Footer';
---

<Layout title="Mi Carrito | Sansistore">
  <Navbar client:load />
  <main class="mx-auto min-h-screen max-w-5xl px-4 pb-12 pt-24 sm:px-6 sm:pt-28">
    <section class="rounded-[2rem] border border-border-light bg-card-bg-light p-6 shadow-sm sm:p-8">
      <p class="text-xs font-semibold uppercase tracking-[0.22em] text-primary">
        Compra actual
      </p>
      <h1 class="mt-2 text-3xl font-black text-text-light">Mi Carrito</h1>

      <div id="cart-status" class="mt-8 text-sm text-text-light opacity-70">
        Cargando carrito...
      </div>
    </section>
  </main>
  <Footer client:load />

  <script>
    import { onAuthStateChanged } from 'firebase/auth';
    import {
      collection,
      doc,
      getDoc,
      getDocs,
      limit,
      query,
      where,
    } from 'firebase/firestore';
    import { auth, db } from '../lib/firebase';

    const container = document.getElementById('cart-status');

    const escapeHtml = (text) => {
      const div = document.createElement('div');
      div.textContent = String(text ?? '');
      return div.innerHTML;
    };

    const renderMessage = (html) => {
      if (!container) return;
      container.innerHTML = html;
    };

    const loadProductById = async (productId) => {
      const directSnap = await getDoc(doc(db, 'products', productId));
      if (directSnap.exists()) {
        return { id: directSnap.id, ...directSnap.data() };
      }

      const bySlugSnap = await getDocs(
        query(collection(db, 'products'), where('slug', '==', productId), limit(1))
      );

      if (bySlugSnap.empty) return null;

      return { id: bySlugSnap.docs[0].id, ...bySlugSnap.docs[0].data() };
    };

    onAuthStateChanged(auth, async (user) => {
      if (!container) return;

      if (!user) {
        renderMessage(`
          <div class="rounded-2xl border border-border-light bg-secondary-bg-light/30 p-5">
            <p class="text-base font-semibold text-text-light">No autenticado</p>
            <a class="mt-3 inline-flex rounded-full border border-primary px-4 py-2 font-semibold text-primary transition-colors hover:bg-primary hover:text-white" href="/login">Iniciar sesión</a>
          </div>
        `);
        return;
      }

      try {
        const cartSnap = await getDocs(collection(db, 'users', user.uid, 'cartItems'));

        if (cartSnap.empty) {
          renderMessage(`
            <div class="rounded-2xl border border-border-light bg-secondary-bg-light/30 p-5">
              <p class="text-base font-semibold text-text-light">Tu carrito está vacío</p>
            </div>
          `);
          return;
        }

        const items = await Promise.all(
          cartSnap.docs.map(async (cartDoc) => {
            const item = cartDoc.data();
            const product = await loadProductById(item.productId);
            return {
              id: cartDoc.id,
              quantity: Number(item.quantity ?? 0),
              product,
            };
          })
        );

        const visibleItems = items.filter((item) => item.product);

        if (visibleItems.length === 0) {
          renderMessage(`
            <div class="rounded-2xl border border-border-light bg-secondary-bg-light/30 p-5">
              <p class="text-base font-semibold text-text-light">Tu carrito está vacío</p>
            </div>
          `);
          return;
        }

        renderMessage(`
          <div class="grid gap-4">
            ${visibleItems
              .map(
                (item) => `
                  <article class="rounded-2xl border border-border-light bg-secondary-bg-light/20 p-5">
                    <div class="flex items-start justify-between gap-4">
                      <div>
                        <h2 class="text-lg font-bold text-text-light">${escapeHtml(item.product.name)}</h2>
                        <p class="mt-1 text-sm text-text-light opacity-70">Cantidad: ${escapeHtml(item.quantity)}</p>
                      </div>
                      <a class="text-sm font-semibold text-primary hover:underline" href="/productos/${escapeHtml(item.product.slug)}">Ver detalle</a>
                    </div>
                  </article>
                `
              )
              .join('')}
          </div>
        `);
      } catch {
        renderMessage(`
          <div class="rounded-2xl border border-border-light bg-secondary-bg-light/30 p-5">
            <p class="text-base font-semibold text-text-light">No se pudo cargar el carrito.</p>
          </div>
        `);
      }
    });
  </script>
</Layout>
