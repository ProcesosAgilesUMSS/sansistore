---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import Footer from '../components/Footer';
import { CartProvider, CartView } from '../features/cart';
---

<Layout title="Mi Carrito | SansiStore">
  <Navbar client:load />
  <main class="cart-page max-w-6xl mx-auto px-4 sm:px-6 pt-20 pb-12">
    <h1 class="text-2xl font-bold mb-6">Mi Carrito</h1>
    <CartView client:load />
  </main>
  <Footer client:idle />
</Layout>