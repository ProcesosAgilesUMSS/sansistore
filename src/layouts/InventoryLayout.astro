---
import Layout from './Layout.astro';
import StockAlertToast from '../features/inventory/components/StockAlertToast.tsx';
import Navbar from '../components/Navbar';
import RouteGuard from '../components/RouteGuard';
import AppNavSidebar from '../components/AppNavSidebar';

interface Props {
  title?: string;
}

const { title = 'Sansistore | Inventario' } = Astro.props;
const pathname = Astro.url.pathname;
---

<Layout title={title}>
  <div class="flex flex-col min-h-screen bg-(--theme-bg)">
    <Navbar client:load />

    <RouteGuard
      client:load
      allowedRoles={['operador_inv']}
      roleName="Inventario"
    >
      <div class="flex flex-1 min-h-0 pt-14">
        <AppNavSidebar client:load nav="inventory" pathname={pathname} title="Inventario" />

        <main class="flex-1 min-w-0 p-6 md:p-8">
          <StockAlertToast client:load />
          <div class="mx-auto w-full max-w-7xl">
            <slot />
          </div>
        </main>
      </div>
    </RouteGuard>
  </div>
</Layout>
