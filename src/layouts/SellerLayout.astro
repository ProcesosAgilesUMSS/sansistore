---
import Layout from './Layout.astro';
import Navbar from '../components/Navbar';
import Footer from '../components/Footer';
import RouteGuard from '../components/RouteGuard';
import OrdersDock from '../features/orders/components/OrdersDock';

interface Props {
  title?: string;
}

const { title = 'Sansistore | Vendedor' } = Astro.props;
---

<Layout title={title}>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <Navbar client:load />
  <OrdersDock client:load transition:persist />
  <RouteGuard client:load allowedRoles={['vendedor']} roleName="Vendedor">
    <main class="bg-(--theme-bg) pt-16 md:pt-20 font-['Inter',sans-serif] flex-1 flex flex-col w-full">
      <slot />
    </main>
  </RouteGuard>
  <Footer client:load className="pb-36 lg:pb-24" />
</Layout>
